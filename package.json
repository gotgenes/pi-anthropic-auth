{
  "name": "@gotgenes/pi-anthropic-auth",
  "version": "0.6.4",
  "description": "Pi extension package for Anthropic OAuth compatibility",
  "author": {
    "name": "Chris Lasher"
  },
  "packageManager": "pnpm@11.5.3",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "anthropic",
    "oauth"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/pi-anthropic-auth.git"
  },
  "homepage": "https://github.com/gotgenes/pi-anthropic-auth#readme",
  "bugs": {
    "url": "https://github.com/gotgenes/pi-anthropic-auth/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:health": "fallow health --score --hotspots --targets",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "lint:md": "rumdl check *.md docs/**/*.md",
    "lint": "biome check . && eslint . && pnpm run lint:md",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.79.1",
    "@earendil-works/pi-coding-agent": ">=0.79.1"
  },
  "devDependencies": {
    "fallow": "^2.91.0",
    "@biomejs/biome": "^2.4.16",
    "@earendil-works/pi-ai": "0.79.1",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@types/node": "^22.15.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "rumdl": "^0.2.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
